{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & (Join-Path $root 'scripts/codex-stop-hook.ps1')\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & (Join-Path $root 'scripts/codex-stop-hook.ps1')\"",
            "timeout": 10,
            "statusMessage": "Checking agent automation trigger"
          }
        ]
      }
    ]
  }
}

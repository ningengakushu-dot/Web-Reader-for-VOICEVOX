{
  "manifest_version": 3,
  "name": "Web Reader for VOICEVOX",
  "version": "1.1.0",
  "description": "閲覧中のWEBページの選択しているテキストのみを読み上げてくれるアプリです。(This extension is designed to read Japanese text aloud.)",
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "offscreen"
  ],
  "commands": {
    "toggle-reading": {
      "suggested_key": {
        "default": "Alt+Shift+U",
        "mac": "Alt+Shift+U"
      },
      "description": "選択したテキストの読み上げを開始/停止します"
    }
  },
  "host_permissions": [
    "http://127.0.0.1:50021/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  }
}
